# Supabase 配置
# 从Supabase项目设置中获取这些值：Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# 游戏配置
VITE_GAME_TITLE=BrickPush 推箱子游戏
VITE_GAME_VERSION=1.0.0

# 开发配置
VITE_DEV_MODE=true
VITE_DEBUG_ENABLED=false

# 联机功能配置 (未来)
VITE_MULTIPLAYER_ENABLED=false
VITE_MAX_PLAYERS_PER_ROOM=2

# 注意：
# 1. 复制此文件为 .env.local 进行本地开发
# 2. 在GitHub Pages部署时，需要在仓库的Settings → Secrets中设置这些环境变量
# 3. 不要将真实的API密钥提交到版本控制